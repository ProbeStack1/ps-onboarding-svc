            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"ACTIVE\",\n  \"consumerIds\": [\"{{consumerId}}\"]\n}" },
            "url": "{{baseUrl}}/api/v1/onboarding/applications/{{applicationId}}"
          }
        },
        {
          "name": "Replace Application Consumers",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"consumerIds\": [\"{{consumerId}}\"]\n}" },
            "url": "{{baseUrl}}/api/v1/onboarding/applications/{{applicationId}}/consumers"
          }
        },
        {
          "name": "Application History",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/applications/{{applicationId}}/history"
          }
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "url": "{{baseUrl}}/api/v1/onboarding/applications/{{applicationId}}"
          }
        }
