          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/applications/{{applicationId}}"
