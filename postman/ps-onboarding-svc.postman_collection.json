                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessUnitId\": \"{{businessUnitId}}\",\n  \"projectId\": \"{{projectId}}\",\n  \"name\": \"InventoryTeam\",\n  \"applicationId\": \"APP-2026-001\",\n  \"ownerName\": \"Jagruti\",\n  \"ownerEmail\": \"owner@example.com\",\n  \"applicationSme\": \"Inventory SME\",\n  \"smeEmail\": \"sme@example.com\",\n  \"testerName\": \"QA User\",\n  \"testerEmail\": \"tester@example.com\",\n  \"serviceNowGroupName\": \"SN-Inventory\",\n  \"serviceNowEmail\": \"servicenow@example.com\",\n  \"status\": \"DRAFT\",\n  \"consumerIds\": [\"{{consumerId}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/onboarding/applications"
          }
        },
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/applications?projectId={{projectId}}&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "onboarding", "applications"],
              "query": [
                { "key": "projectId", "value": "{{projectId}}" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "businessUnitId", "value": "{{businessUnitId}}", "disabled": true },
                { "key": "status", "value": "ACTIVE", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
