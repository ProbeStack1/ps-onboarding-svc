{
  "info": {
    "name": "ProbeStack Onboarding Service",
    "description": "Postman collection for ps-onboarding-svc. Uses header-based organization and actor identity. Run the create requests in this order for the happy path: Consumer, Business Unit, Project, Application.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8084/onboarding-api" },
    { "key": "organizationId", "value": "org-demo-001" },
    { "key": "userId", "value": "user-demo-001" },
    { "key": "userEmail", "value": "admin@probestack.io" },
    { "key": "userName", "value": "ProbeStack Admin" },
    { "key": "userRole", "value": "ADMIN" },
    { "key": "businessUnitId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "applicationId", "value": "" },
    { "key": "consumerId", "value": "" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is JSON', function () {",
          "  pm.response.to.have.header('Content-Type');",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Business Units",
      "item": [
        {
          "name": "Create Business Unit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Business unit created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) pm.collectionVariables.set('businessUnitId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wealth Management\",\n  \"code\": \"WEALTH\",\n  \"ownerName\": \"Jagruti\",\n  \"ownerEmail\": \"owner@example.com\",\n  \"costCenter\": \"CC-1001\",\n  \"description\": \"Owns wealth domain onboarding.\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/onboarding/business-units"
          }
        },
        {
          "name": "List Business Units",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/business-units?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "onboarding", "business-units"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "ACTIVE", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Business Unit",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/business-units/{{businessUnitId}}"
          }
        },
        {
          "name": "Update Business Unit",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated business unit description.\",\n  \"status\": \"ACTIVE\"\n}" },
            "url": "{{baseUrl}}/api/v1/onboarding/business-units/{{businessUnitId}}"
          }
        },
        {
          "name": "Business Unit Tree",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/business-units/{{businessUnitId}}/tree"
          }
        },
        {
          "name": "Business Unit History",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/business-units/{{businessUnitId}}/history"
          }
        },
        {
          "name": "Delete Business Unit",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "url": "{{baseUrl}}/api/v1/onboarding/business-units/{{businessUnitId}}"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Project created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) pm.collectionVariables.set('projectId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessUnitId\": \"{{businessUnitId}}\",\n  \"name\": \"Inventory Modernization\",\n  \"code\": \"INV-MOD\",\n  \"ownerName\": \"Jagruti\",\n  \"ownerEmail\": \"owner@example.com\",\n  \"projectDlEmail\": \"project-dl@example.com\",\n  \"expectedGoLiveDate\": \"2026-08-15\",\n  \"deliveryModel\": \"Agile\",\n  \"status\": \"READY\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/onboarding/projects"
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/projects?businessUnitId={{businessUnitId}}&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "onboarding", "projects"],
              "query": [
                { "key": "businessUnitId", "value": "{{businessUnitId}}" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "status", "value": "READY", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/projects/{{projectId}}"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"deliveryModel\": \"Agile delivery\",\n  \"status\": \"READY\"\n}" },
            "url": "{{baseUrl}}/api/v1/onboarding/projects/{{projectId}}"
          }
        },
        {
          "name": "Project Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/projects/{{projectId}}/applications"
          }
        },
        {
          "name": "Project History",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Organization-Id", "value": "{{organizationId}}" }],
            "url": "{{baseUrl}}/api/v1/onboarding/projects/{{projectId}}/history"
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Organization-Id", "value": "{{organizationId}}" },
              { "key": "X-User-Id", "value": "{{userId}}" },
              { "key": "X-User-Email", "value": "{{userEmail}}" },
              { "key": "X-User-Name", "value": "{{userName}}" },
              { "key": "X-User-Role", "value": "{{userRole}}" }
            ],
            "url": "{{baseUrl}}/api/v1/onboarding/projects/{{projectId}}"
          }
        }
      ]
    },
    {
      "name": "Applications",
